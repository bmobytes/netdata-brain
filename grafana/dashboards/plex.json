          "query": "from(bucket: \"plex\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r._measurement == \"prometheus\" and r._field == \"server_info\")\n  |> last()\n  |> map(fn: (r) => ({r with _value: 1.0, _field: r.platform + \" \" + r.platform_version + \" \u2022 Plex \" + r.version}))",

      "type": "table",
      "title": "Disk Temperatures (°C)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "influxdb", "uid": "cfecbpgdhs5j4b" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [

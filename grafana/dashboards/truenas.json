      "fieldConfig": {
        "defaults": {
          "unit": "TB",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 20 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "cfecbpgdhs5j4b" },
          "query": "from(bucket: \"netdata\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"truenas_pool\" and r._field == \"free_bytes\")\n  |> last()\n  |> map(fn: (r) => ({r with _value: float(v: r._value) / 1099511627776.0}))"
        }

              { "color": "yellow", "value": 40 },
              { "color": "red", "value": 50 }
            ]
          },
          "custom": {
            "displayMode": "color-background"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "_field" },
            "properties": [{ "id": "displayName", "value": "Disk" }]
          },
          {
            "matcher": { "id": "byName", "options": "_value" },
            "properties": [
              { "id": "displayName", "value": "Temp (°C)" },
              { "id": "unit", "value": "celsius" },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "_field", "desc": false }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "cfecbpgdhs5j4b" },
          "query": "from(bucket: \"netdata\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"truenas_disk_temp\" and r._field == \"temp_celsius\")\n  |> last()\n  |> map(fn: (r) => ({r with _field: r.disk}))\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        { "id": "organize", "options": {} }
      ]

      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "cfecbpgdhs5j4b" },
          "query": "from(bucket: \"netdata\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"truenas_pool\" and r._field == \"used_bytes\")\n  |> map(fn: (r) => ({r with _value: float(v: r._value) / 1099511627776.0}))"
        }
      ]
    },
    {
      "id": 300,
      "type": "row",
      "title": "Datasets",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 20,
      "type": "barchart",
      "title": "Dataset Breakdown (GB Used)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "datasource": { "type": "influxdb", "uid": "cfecbpgdhs5j4b" },
      "fieldConfig": {
        "defaults": {
          "unit": "GB",
          "decimals": 1,
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "cfecbpgdhs5j4b" },
          "query": "import \"strings\"\nfrom(bucket: \"netdata\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"truenas_dataset\" and r._field == \"used_bytes\")\n  |> filter(fn: (r) => not strings.hasPrefix(v: r.dataset, prefix: \"Archive/iocage/\") and not strings.hasPrefix(v: r.dataset, prefix: \"Archive/TimeMachine/\"))\n  |> last()\n  |> map(fn: (r) => ({r with _value: float(v: r._value) / 1073741824.0, _field: r.dataset}))\n  |> keep(columns: [\"_time\", \"_value\", \"_field\"])\n  |> sort(columns: [\"_value\"], desc: true)"
        }
      ]
    },
    {
      "id": 400,
      "type": "row",
